{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "cuekjs",
    "paths": {
      "@/*": ["src/*"],
      "cuekjs": ["../../packages/cuek/src/index.ts"],
      "cuekjs/jsx-runtime": ["../../packages/cuek/src/jsx-runtime.ts"],
      "cuekjs/jsx-dev-runtime": ["../../packages/cuek/src/jsx-runtime.ts"]
    }
  }
}
