{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "rin-lib",
    "paths": {
      "@/*": ["src/*"],
      "rin-lib": ["../../packages/rin/src/index.ts"],
      "rin-lib/jsx-runtime": ["../../packages/rin/src/jsx-runtime.ts"],
      "rin-lib/jsx-dev-runtime": ["../../packages/rin/src/jsx-runtime.ts"]
    }
  }
}
