---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Rin — Hyper-minimalist JSX Framework">
  
  {/* Hero */}
  <section class="flex flex-col items-center text-center px-6 pt-24 pb-20 max-w-screen-xl mx-auto">
    <a
      href="https://github.com/hulahulaxl/rin/releases"
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-2 mb-8 px-3 py-1 rounded-full border border-zinc-200 bg-zinc-50 text-xs font-medium text-zinc-600 hover:border-zinc-300 hover:bg-white transition-colors"
    >
      <span class="flex h-1.5 w-1.5 rounded-full bg-zinc-900"></span>
      v0.2.0 released
      <svg class="w-3 h-3 ml-0.5 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>

    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-zinc-950 leading-[1.1] max-w-3xl">
      The web framework that <em class="not-italic text-zinc-400">gets out of the way.</em>
    </h1>

    <p class="mt-6 max-w-xl text-lg text-zinc-500 leading-relaxed">
      Rin is a hyper-minimalist JSX framework with no Virtual DOM. It renders native HTML strings on the server and surgically patches the DOM on the client.
    </p>

    <div class="mt-8 flex flex-col sm:flex-row items-center gap-3">
      <a
        href="/guide"
        class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-zinc-950 text-white text-sm font-medium hover:bg-zinc-800 transition-colors"
      >
        Get started
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="https://github.com/hulahulaxl/rin"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border border-zinc-200 bg-white text-sm font-medium text-zinc-700 hover:border-zinc-300 hover:bg-zinc-50 transition-colors"
      >
        <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        View on GitHub
      </a>
    </div>

    {/* Code snippet teaser */}
    <div class="mt-14 w-full max-w-2xl text-left rounded-xl border border-zinc-200 bg-zinc-50 overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-zinc-200">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-zinc-200"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-200"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-200"></span>
        </div>
        <span class="text-xs text-zinc-400 font-mono ml-1">Counter.tsx</span>
      </div>
      <pre class="p-5 text-sm font-mono text-zinc-700 overflow-x-auto leading-relaxed"><code>{"function Counter({}, ctx) {\n  let count = 0;\n\n  return () => (\n    <div class=\"counter\">\n      <p>Count: {count}</p>\n      <button onclick={() => { count++; ctx.rerender(); }}>\n        Increment\n      </button>\n    </div>\n  );\n}"}</code></pre>
    </div>
  </section>

  {/* Features */}
  <section class="border-t border-zinc-100 px-6 py-20 max-w-screen-xl mx-auto w-full">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-100 border border-zinc-100 rounded-xl overflow-hidden">
      
      <div class="bg-white px-8 py-8">
        <div class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-900">
          <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
        </div>
        <h3 class="font-semibold text-zinc-900 mb-2">Zero Virtual DOM</h3>
        <p class="text-sm text-zinc-500 leading-relaxed">
          Skip the diffing overhead entirely. Rin patches the physical DOM directly — only what changed, nothing more.
        </p>
      </div>

      <div class="bg-white px-8 py-8">
        <div class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-900">
          <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
          </svg>
        </div>
        <h3 class="font-semibold text-zinc-900 mb-2">Vanilla HTML Attributes</h3>
        <p class="text-sm text-zinc-500 leading-relaxed">
          No magic. Use <code class="text-xs bg-zinc-100 px-1 py-0.5 rounded font-mono">class</code> not <code class="text-xs bg-zinc-100 px-1 py-0.5 rounded font-mono">className</code>. Events are lowercase. It works exactly like the browser.
        </p>
      </div>

      <div class="bg-white px-8 py-8">
        <div class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-900">
          <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
          </svg>
        </div>
        <h3 class="font-semibold text-zinc-900 mb-2">Astro Native</h3>
        <p class="text-sm text-zinc-500 leading-relaxed">
          First-party Astro integration with server-side rendering and selective hydration via <code class="text-xs bg-zinc-100 px-1 py-0.5 rounded font-mono">client:load</code>.
        </p>
      </div>

    </div>
  </section>

</Layout>
