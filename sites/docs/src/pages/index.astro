---
import Layout from "../layouts/Layout.astro";
import { Code } from "astro:components";
import { homepageData } from "../config/homepage";

const { hero, codeSnippet, features } = homepageData;
---
<Layout title="Cuek — Hyper-minimalist JSX Framework">
  
  {/* Hero */}
  <section class="flex flex-col items-center text-center px-6 pt-32 pb-24 max-w-screen-xl mx-auto">
    
    <svg class="w-24 h-24 text-zinc-900 mb-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="12 2 2 22 22 22" />
    </svg>

    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-950 mb-6">
      {hero.title}
    </h1>

    <p class="max-w-2xl text-xl text-zinc-500 leading-relaxed font-light">
      {hero.description}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
      <a
        href={hero.primaryCta.href}
        class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg bg-zinc-950 text-white text-sm font-medium hover:bg-zinc-800 transition-colors"
      >
        {hero.primaryCta.text}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href={hero.secondaryCta.href}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg border border-zinc-200 bg-white text-sm font-medium text-zinc-700 hover:border-zinc-300 hover:bg-zinc-50 transition-colors"
      >
        <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        {hero.secondaryCta.text}
      </a>
    </div>

    {/* Code snippet teaser */}
    <div class="mt-14 w-full max-w-2xl text-left rounded-xl border border-zinc-200 bg-white overflow-hidden shadow-sm">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-zinc-200 bg-zinc-50">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-zinc-200"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-200"></span>
          <span class="w-3 h-3 rounded-full bg-zinc-200"></span>
        </div>
        <span class="text-xs text-zinc-400 font-mono ml-1">{codeSnippet.filename}</span>
      </div>
      <div class="p-5 text-sm font-mono overflow-x-auto leading-relaxed [&>pre]:!bg-transparent [&>pre]:!p-0 [&>pre]:!m-0">
        <Code code={codeSnippet.code} lang="tsx" theme="github-light" />
      </div>
    </div>
  </section>

  {/* Features */}
  <section class="px-6 py-20 max-w-7xl mx-auto w-full">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px overflow-hidden">
      
      {features.map((feature) => (
        <div class="bg-white px-8 py-8">
          <div class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-900">
            <svg class="h-4.5 w-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d={feature.iconPath} />
            </svg>
          </div>
          <h3 class="font-semibold text-zinc-900 mb-2">{feature.title}</h3>
          <p class="text-sm text-zinc-500 leading-relaxed" set:html={feature.description} />
        </div>
      ))}

    </div>
  </section>

</Layout>
