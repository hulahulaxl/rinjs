---
import "../styles/global.css";
import Header from "../components/Header";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The hyper-minimalist JSX framework." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-zinc-900 antialiased min-h-screen flex flex-col selection:bg-black selection:text-white">
    <Header client:load />
    <div class="flex-1 w-full max-w-5xl mx-auto px-6 lg:px-8">
      <slot />
    </div>
  </body>
</html>
