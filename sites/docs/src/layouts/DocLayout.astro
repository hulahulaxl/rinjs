---
import "../styles/global.css";
import { getCollection, type CollectionEntry } from "astro:content";
import Header from "../components/Header";
import Sidebar from "../components/Sidebar";
import SearchModal from "../components/SearchModal";

interface Props {
  title: string;
  section: "guide" | "api";
}

export interface NavItem {
  title: string;
  href: string;
}

export interface NavSection {
  title: string;
  items: NavItem[];
}

const { title, section } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "");

const allEntries = await getCollection("docs", ({ id }: CollectionEntry<"docs">) =>
  id.startsWith(`${section}/`)
);
allEntries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const sectionMap = new Map<string, { title: string; href: string }[]>();
for (const entry of allEntries) {
  const cat = entry.data.category;
  const slug = entry.id.replace(`${section}/`, "").replace(/\.(md|mdx)$/, "");
  if (!sectionMap.has(cat)) sectionMap.set(cat, []);
  sectionMap.get(cat)!.push({ title: entry.data.title, href: `/${section}/${slug}` });
}

const nav: NavSection[] = Array.from(sectionMap.entries()).map(([catTitle, items]) => ({
  title: catTitle,
  items,
}));

// Pagination
const normalizedPath = currentPath.replace(/\/$/, "");
const currentIndex = allEntries.findIndex((entry) => {
  const slug = entry.id.replace(`${section}/`, "").replace(/\.(md|mdx)$/, "");
  return `/${section}/${slug}` === normalizedPath;
});

const prevEntry = currentIndex > 0 ? allEntries[currentIndex - 1] : null;
const nextEntry = currentIndex < allEntries.length - 1 ? allEntries[currentIndex + 1] : null;

const getEntryHref = (entry: CollectionEntry<"docs">) =>
  `/${section}/${entry.id.replace(`${section}/`, "").replace(/\.(md|mdx)$/, "")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={title} />
    <title>{title} | Cuek</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white text-zinc-900 min-h-screen antialiased selection:bg-zinc-900 selection:text-white">

    <!-- Sticky Header island -->
    <Header client:load currentPath={currentPath} />

    <!-- Page body: sidebar + content -->
    <div class="w-full max-w-screen-xl mx-auto px-6 flex items-start">

      <!-- Sidebar island — self-contained, listens for toggle event -->
      <Sidebar client:load nav={nav} currentPath={currentPath} />

      <!-- Static MDX content — never inside a Cuek island -->
      <main data-pagefind-body class="flex-1 min-w-0 pl-10 lg:pl-14 pr-2 py-12 max-w-3xl">
        <article>
          <slot />
        </article>

        {/* Pagination */}
        {(prevEntry || nextEntry) && (
          <div class="mt-20 pt-8 border-t border-zinc-100 flex flex-col sm:flex-row gap-4 items-center justify-between">
            {prevEntry ? (
              <a
                href={getEntryHref(prevEntry)}
                class="group flex flex-col gap-2 p-4 rounded-xl border border-zinc-100 hover:border-zinc-200 hover:bg-zinc-50 transition-all w-full sm:w-auto min-w-[200px]"
              >
                <span class="text-xs text-zinc-400 font-medium flex items-center gap-1">
                  <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                  </svg>
                  Previous
                </span>
                <span class="text-sm font-semibold text-zinc-900 leading-tight">
                  {prevEntry.data.title}
                </span>
              </a>
            ) : <div />}

            {nextEntry && (
              <a
                href={getEntryHref(nextEntry)}
                class="group flex flex-col gap-2 p-4 rounded-xl border border-zinc-100 hover:border-zinc-200 hover:bg-zinc-50 transition-all w-full sm:w-auto min-w-[200px] text-right"
              >
                <span class="text-xs text-zinc-400 font-medium flex items-center justify-end gap-1">
                  Next
                  <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </span>
                <span class="text-sm font-semibold text-zinc-900 leading-tight">
                  {nextEntry.data.title}
                </span>
              </a>
            )}
          </div>
        )}
      </main>

    </div>

    <SearchModal client:load />
  </body>
</html>
