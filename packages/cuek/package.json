{
  "name": "cuekjs",
  "version": "0.3.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./jsx-runtime": {
      "development": "./src/jsx-runtime.ts",
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    },
    "./jsx-dev-runtime": {
      "development": "./src/jsx-runtime.ts",
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js",
      "require": "./dist/jsx-runtime.cjs"
    }
  },
  "keywords": [],
  "author": "Hula Hula",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hulahulaxl/cuek.git"
  },
  "bugs": {
    "url": "https://github.com/hulahulaxl/cuek/issues"
  },
  "homepage": "https://github.com/hulahulaxl/cuek#readme"
}
